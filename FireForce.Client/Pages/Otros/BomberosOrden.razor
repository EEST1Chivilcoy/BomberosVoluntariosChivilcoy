@using FireForce.Data.Models.Personas.Personal
@using FireForce.Data.Models.Personas.Personal.Componentes
@using FireForce.Client.Pages.Personal.ABM.Componentes.Bomberos
@using FireForce.Client.Data.Mappers
@using FireForce.Data.Models.DTO

@page "/fire-force/Orden"

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "AdminOnly")]

@using FireForce.Client.Services
@inject IBomberoService BomberoService
@inject NavigationManager Navigation
@inject IMessageService MessageService

<style>
    .orden-abm {
        --primary: #A63333;
        --primary-dark: #732D2D;
        --success: #4CAF50;
        --success-dark: #438E46;
        --accent: #FFD54F;
    }

        .orden-abm .page-container {
            padding: 12px;
            min-height: 100vh;
        }

        .orden-abm .main-card {
            background: rgba(255,255,255,.96);
            backdrop-filter: blur(10px);
            border-radius: 16px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,.2);
            box-shadow: 0 8px 32px rgba(166,51,51,.10), 0 4px 16px rgba(0,0,0,.05);
        }

        .orden-abm .header-section {
            position: relative;
            overflow: hidden;
            padding: 28px;
            color: white;
            background: linear-gradient( 135deg, var(--primary), var(--primary-dark) );
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .orden-abm .main-title {
            margin: 0;
            font-size: 2.2rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 14px;
            animation: glow 2s infinite alternate;
            position: relative;
            z-index: 2;
        }

        .orden-abm .title-icon {
            color: var(--accent);
            font-size: 2rem;
        }

    @@keyframes glow {
        from {
            text-shadow: 0 0 5px #F9A825, 0 0 10px #FFD54F;
        }

        to {
            text-shadow: 0 0 14px #F9A825, 0 0 25px #FFD54F;
        }
    }

    .lava-bubbles {
        position: absolute;
        inset: 0;
        overflow: hidden;
    }

    .lava-bubble {
        position: absolute;
        border-radius: 50%;
        background: radial-gradient( circle, #FFD54F, transparent );
        opacity: .35;
        animation: bubble 8s linear infinite;
    }

    .b1 {
        width: 70px;
        height: 70px;
        left: 10%;
    }

    .b2 {
        width: 90px;
        height: 90px;
        left: 40%;
        animation-delay: 2s;
    }

    .b3 {
        width: 60px;
        height: 60px;
        left: 70%;
        animation-delay: 4s;
    }

    @@keyframes bubble {
        from {
            transform: translateY(120px);
        }

        to {
            transform: translateY(-280px);
            opacity: 0;
        }
    }

    .table-wrapper {
        padding: 24px;
    }

    .scroll {
        max-height: 720px;
        overflow-y: auto;
        border-radius: 12px;
    }

    .custom-grid {
        width: 100%;
        border-collapse: collapse;
    }

        .custom-grid th {
            background: var(--primary);
            color: white;
            padding: 16px;
            font-weight: 700;
            border: none;
        }

        .custom-grid td {
            padding: 16px;
            border-bottom: 1px solid #f0f0f0;
        }

    .bombero-row {
        transition: .25s;
        cursor: grab;
    }

        .bombero-row:hover {
            background: #fff8f8;
        }

        .bombero-row.dragging {
            opacity: .45;
        }

        .bombero-row.drag-over {
            background: #fff0f0;
            outline: 2px dashed var(--primary);
        }

    .orden-badge {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background: linear-gradient( 135deg, #ffd54f, #ffb300 );
        color: #732D2D;
        font-weight: bold;
    }

    .handle {
        font-size: 20px;
        margin-right: 10px;
        color: #888;
    }

    .footer-actions {
        padding: 24px;
        display: flex;
        justify-content: flex-end;
    }

    .orden-abm .btn-confirmar {
        height: 56px !important;
        min-width: 240px !important;
        padding: 0 32px !important;
        border: none !important;
        border-radius: 10px !important;
        font-size: 1.1rem !important;
        font-weight: 700 !important;
        color: white !important;
        background: linear-gradient( 135deg, #4CAF50 0%, #438E46 100% ) !important;
        box-shadow: 0 4px 12px rgba(76,175,80,.30) !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        gap: 10px !important;
        transition: all .30s cubic-bezier(.4,0,.2,1) !important;
    }

        .orden-abm .btn-confirmar:hover {
            transform: translateY(-3px) !important;
            background: linear-gradient( 135deg, #388E3C 0%, #4CAF50 100% ) !important;
            box-shadow: 0 8px 22px rgba(76,175,80,.40) !important;
        }

        .orden-abm .btn-confirmar:active {
            transform: translateY(-1px) scale(.98) !important;
        }

        .orden-abm .btn-confirmar[disabled] {
            opacity: .65;
        }

    .loading-wrap {
        padding: 50px;
        text-align: center;
    }
</style>

<div class="orden-abm">

    <div class="page-container">

        <Card Class="main-card">

            <div class="header-section">

                <div class="lava-bubbles">
                    <div class="lava-bubble b1"></div>
                    <div class="lava-bubble b2"></div>
                    <div class="lava-bubble b3"></div>
                </div>

                <h1 class="main-title">
                    <Icon Type="fire" Class="title-icon" />
                    ORDEN DEL PERSONAL
                </h1>

                <Button Class="btn-confirmar"
                        OnClick="ConfirmarOrden"
                        Loading="@isLoading"
                        Icon="save">

                    GUARDAR ORDEN

                </Button>

            </div>

            <div class="table-wrapper">

                @if (isLoading)
                {
                    <div class="loading-wrap">
                        <Spin />
                    </div>
                }
                else
                {
                    <div class="scroll">

                        <table class="custom-grid">

                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Foto</th>
                                    <th>Apellido y Nombre</th>
                                    <th>Legajo</th>
                                    <th>Jerarquía</th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var (bombero, index)
                                                            in bomberos.Select((b, i) => (b, i)))
                                {
                                    <tr class="bombero-row
                                                @(dragSrcId == bombero.Id ? "dragging" : "")
                                                @(dragOverId == bombero.Id ? "drag-over" : "")"
                                        draggable="true"
                                        @ondragstart="() => OnDragStart(bombero.Id)"
                                        @ondragover:preventDefault
                                        @ondragover="() => OnDragOver(bombero.Id)"
                                        @ondrop="() => OnDrop(bombero.Id)">

                                        <td>

                                            <span class="handle">
                                                ☰
                                            </span>

                                            <span class="orden-badge">
                                                @(index + 1)
                                            </span>

                                        </td>

                                        <td>

                                            <Avatar Size="AvatarSize.Large"
                                                    Src="@bombero.UrlImagen"
                                                    Icon="user" />

                                        </td>

                                        <td>
                                            @bombero.ApellidoYNombre
                                        </td>

                                        <td>
                                            @bombero.NumeroLegajo
                                        </td>

                                        <td>
                                            @bombero.Grado
                                        </td>

                                    </tr>
                                }

                            </tbody>

                        </table>

                    </div>
                }

            </div>

        </Card>

    </div>

</div>

@code {
    private bool isLoading = true;

    List<BomberoViweModel>? bomberos;
    List<BomberoViweModel>? SinFiltrar;

    private int? dragSrcId = null;
    private int? dragOverId = null;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
       await CargarBomberos();
        isLoading = false;
    }

    private async Task CargarBomberos()
    {
        var resultado = await BomberoService.ObtenerTodosLosBomberosAsync(ConImagenes: true);
        if(resultado == null || !resultado.Any())
        {
           await MessageService.ErrorAsync("No se pudieron cargar los bomberos. Intente nuevamente más tarde.");
            return;
        }
        SinFiltrar = resultado.ToBomberoViewModelList()
                              .OrderBy(b => b.Grado)
                              .ThenBy(b => b.OrdenPersonalizado)
                              .ToList();
        bomberos = SinFiltrar;
    }

    private void OnDragStart(int id) => dragSrcId = id;

    private void OnDragOver(int id) => dragOverId = id;

    private void OnDragLeave() => dragOverId = null;

    private void OnDrop(int dstId)
    {
        if (dragSrcId == null || dragSrcId == dstId) return;

        var srcItem = bomberos!.First(b => b.Id == dragSrcId);
        var srcIdx = bomberos!.IndexOf(srcItem);
        var dstIdx = bomberos!.IndexOf(bomberos.First(b => b.Id == dstId));

        bomberos.RemoveAt(srcIdx);
        bomberos.Insert(dstIdx, srcItem);

        RecalcularOrden();

        dragSrcId = null;
        dragOverId = null;
    }

    private void RecalcularOrden()
    {
        for (int i = 0; i < bomberos!.Count; i++)
            bomberos[i].OrdenPersonalizado = i + 1;
    }

    private async Task ConfirmarOrden()
    {
        var ordenDTO = bomberos!.Select(b => new ActualizarOrdenDTO
        {
            Id = b.Id,
            OrdenPersonalizado = b.OrdenPersonalizado!.Value
        }).ToList();

        var ok = await BomberoService.GuardarOrdenAsync(ordenDTO);

        if (ok)
            await MessageService.SuccessAsync("Orden guardado correctamente.");
        else
            await MessageService.ErrorAsync("Error al guardar el orden."); ;
    }
}